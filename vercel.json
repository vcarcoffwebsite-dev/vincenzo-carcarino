{
  "version": 2,

  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],


"routes": [
  {
    "src": "/api/(.*)",
    "dest": "/api/$1"
  },
  {
    "src": "/admin/(.*)",
    "dest": "/admin/index.html"
  },
  {
    "src": "/admin",
    "dest": "/admin/index.html"
  },
  {
    "src": "/(.*)",
    "dest": "/index.html"
  }
]


  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
